# Docker Compose / container runtime
NODE_ENV=development
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
VITE_GITHUB_CLIENT_ID=your-github-client-id
VITE_GITHUB_REDIRECT_URI=http://localhost
VITE_API_URL=http://localhost:3001
VITE_CSRF_COOKIE_NAME=autosecure_csrf
FRONTEND_URL=http://localhost
DB_NAME=cicd_generator
DB_USER=postgres
DB_PASSWORD=change-me
LOG_LEVEL=info
ALLOWED_SCAN_BASE_DIR=/tmp
TOKEN_ENCRYPTION_KEY=replace-with-a-random-32-plus-character-secret
SESSION_COOKIE_NAME=autosecure_session
CSRF_COOKIE_NAME=autosecure_csrf
OAUTH_STATE_COOKIE_NAME=autosecure_oauth_state
COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=168
OAUTH_STATE_TTL_MINUTES=10
