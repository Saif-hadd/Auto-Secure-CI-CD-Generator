# Local backend runtime (outside Docker)
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/cicd_generator
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-random-32-plus-character-secret
LOG_LEVEL=info
ALLOWED_SCAN_BASE_DIR=/tmp
SESSION_COOKIE_NAME=autosecure_session
CSRF_COOKIE_NAME=autosecure_csrf
OAUTH_STATE_COOKIE_NAME=autosecure_oauth_state
COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=168
OAUTH_STATE_TTL_MINUTES=10
